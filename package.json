{
  "name": "card-game",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev:packages:build": "pnpm -r --filter ./packages/** run build",
    "dev:packages": "pnpm -r --parallel --stream --filter ./packages/** run dev",
    "dev:apps": "pnpm -r --parallel --stream --filter ./apps/** run dev",
    "dev:all": "concurrently -k -n PACKAGES,APPS \"pnpm run dev:packages\" \"pnpm run dev:apps\"",
    "dev": "pnpm run dev:packages:build && pnpm run dev:all",

    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "lint:css": "stylelint \"**/*.{css,scss,sass}\"",
    "lint:css:fix": "stylelint \"**/*.{css,scss,sass}\" --fix",
    "typecheck": "pnpm -r run typecheck",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,scss,sass}": [
      "stylelint --fix",
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/stylelint-plugin": "^5.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-next": "^0.0.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "stylelint-config-recess-order": "^7.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "stylelint-scss": "^7.0.0",
    "typescript-eslint": "^8.57.0"
  }
}